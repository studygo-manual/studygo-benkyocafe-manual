# Google OAuth (Google Cloud Console → APIs & Services → Credentials で取得)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# NextAuth
# ローカル: http://localhost:3000
# 本番: Vercelのドメイン(例: https://studygo-manual-private.vercel.app)
NEXTAUTH_URL=http://localhost:3000
# ランダムな文字列(生成コマンド: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-secret-here

# アクセス許可するメールアドレス(カンマ区切り)
ALLOWED_EMAILS=benkyocafe.shinjuku@gmail.com,benkyo-cafe.sbp@b-pt.jp,s_kunimatsu@b-pt.jp,m_kondo@b-pt.jp,sales.studygo@b-pt.jp
